# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Flask configuration
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=1

# Google Gemini API key (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# data.gov.in API key for real market prices (free at https://data.gov.in/)
DATA_GOV_API_KEY=your_data_gov_api_key_here

# Market data settings
MARKET_MODE=api          # api | msp_only
MARKET_CACHE_TTL=86400   # Cache duration in seconds (24 hours)

# Offline modes (offline | gemini | hybrid)
SOIL_IMAGE_MODE=offline
VOICE_NLP_MODE=offline